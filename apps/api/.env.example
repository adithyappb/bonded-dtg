# Copy to `apps/api/.env` for local API.

NODE_ENV=development
HOST=0.0.0.0
PORT=4000
APP_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Min 16 chars in production; dev default exists in code — still set explicitly for clarity.
API_JWT_SECRET=replace-with-long-random-secret

# Supabase: Project Settings → API
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional if you prefer full URL:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

ENABLE_DEV_WALLET_AUTH=true

SUPPORTED_CHAIN_IDS=84532,8453,11155111,1,31337
CHAIN_RPC_URL=https://sepolia.base.org
