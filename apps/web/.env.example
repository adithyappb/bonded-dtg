# Copy to `apps/web/.env.local` for Next.js.

NODE_ENV=development

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Dev email OTP + signed cookie (see root README)
AUTH_DEV_SECRET=change-me-to-a-long-random-string

# Optional Mailpit / local SMTP
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=dev@localhost
