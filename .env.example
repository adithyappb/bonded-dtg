# =============================================================================
# Bonded Project — copy to `.env` at repo root and/or per-app files as noted.
# Never commit real secrets. Replace every placeholder before production.
# =============================================================================

# --- apps/web (.env.local) — Next.js public + server -------------------------
NODE_ENV=development

# Optional: REST API for wallet auth, NFT mint intents, ETH payment intents.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Dev email OTP (Next Route Handlers). Enabled when NODE_ENV=development OR:
# ALLOW_DEV_EMAIL_AUTH=true
AUTH_DEV_SECRET=generate-a-long-random-string-for-cookie-signing

# Optional local SMTP (Mailpit default UI http://127.0.0.1:8025 , SMTP 1025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=dev@localhost
# SMTP_USER=
# SMTP_PASS=

# --- apps/api — Fastify backend (.env next to apps/api) ---------------------
PORT=4000
API_JWT_SECRET=another-long-random-secret-for-jwt-between-api-and-clients

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional RPC / chain (see apps/api/src/config/env.ts for full list)
# BASE_SEPOLIA_RPC_URL=
# COINBASE_CDP_*  — only if you wire CDP; obtain from Coinbase Developer Platform

# --- Supabase CLI (repo /supabase) ------------------------------------------
# SUPABASE_ACCESS_TOKEN from https://supabase.com/dashboard/account/tokens
